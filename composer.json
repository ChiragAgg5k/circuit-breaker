{
    "name": "chiragagg5k/circuit-breaker",
    "description": "A PHP Circuit Breaker implementation to prevent cascading failures",
    "type": "library",
    "keywords": ["circuit-breaker", "fault-tolerance", "resilience"],
    "homepage": "https://github.com/ChiragAgg5k/circuit-breaker",
    "license": "MIT",
    "authors": [
        {
            "name": "Chirag Aggarwal"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "ChiragAgg5k\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ChiragAgg5k\\Tests\\": "tests/"
        }
    },
    "support": {
        "issues": "https://github.com/ChiragAgg5k/circuit-breaker/issues",
        "source": "https://github.com/ChiragAgg5k/circuit-breaker"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
