{
    "name": "chiragagg5k/circuit-breaker",
    "description": "A PHP Circuit Breaker implementation to prevent cascading failures",
    "type": "library",
    "keywords": ["circuit-breaker", "fault-tolerance", "resilience"],
    "homepage": "https://github.com/ChiragAgg5k/circuit-breaker",
    "license": "MIT",
    "authors": [
        {
            "name": "Chirag Aggarwal"
        }
    ],
    "require": {
        "php": "^8.2",
        "utopia-php/telemetry": "0.2.*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^2.1",
        "laravel/pint": "^1.29"
    },
    "suggest": {
        "ext-redis": "Required when using ChiragAgg5k\\CircuitBreaker\\Adapter\\Redis with the phpredis extension.",
        "ext-swoole": "Required when using ChiragAgg5k\\CircuitBreaker\\Adapter\\SwooleTable."
    },
    "autoload": {
        "psr-4": {
            "ChiragAgg5k\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ChiragAgg5k\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyze": "phpstan analyse",
        "format": "pint src tests",
        "format:check": "pint --test src tests",
        "test": "@test:unit",
        "test:unit": "phpunit --testsuite unit",
        "test:e2e": "phpunit --testsuite e2e",
        "test:e2e:docker": "sh -c 'docker compose -p breaker-e2e -f docker-composer.yml up --build --abort-on-container-exit --exit-code-from php; status=$?; docker compose -p breaker-e2e -f docker-composer.yml down -v --remove-orphans; exit $status'",
        "telemetry:up": "docker compose -p breaker-telemetry -f docker-composer.telemetry.yml up -d --build",
        "telemetry:scenario": [
            "Composer\\Config::disableProcessTimeout",
            "docker compose -p breaker-telemetry -f docker-composer.telemetry.yml exec -T demo php examples/telemetry/scenario.php"
        ],
        "telemetry:down": "docker compose -p breaker-telemetry -f docker-composer.telemetry.yml down -v --remove-orphans",
        "test:all": [
            "@test:unit",
            "@test:e2e:docker"
        ]
    },
    "support": {
        "issues": "https://github.com/ChiragAgg5k/circuit-breaker/issues",
        "source": "https://github.com/ChiragAgg5k/circuit-breaker"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    }
}
